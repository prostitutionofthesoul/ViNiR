#!/usr/bin/env bash
# ViNiR setup - iNiR for Void Linux
# Commands: install, update, doctor (or TUI if no args)

cd "$(dirname "$0")"
REPO_ROOT="$(pwd)"

# Handle Ctrl+C gracefully
cleanup() {
    echo ""
    echo -e "\033[33mCancelled.\033[0m"
    exit 130
}
trap cleanup INT
trap 'true' EXIT TERM

###############################################################################
# Colors / TUI helpers
###############################################################################
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

tui_banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  ██╗   ██╗██╗███╗   ██╗██╗██████╗ "
    echo "  ██║   ██║██║████╗  ██║██║██╔══██╗"
    echo "  ██║   ██║██║██╔██╗ ██║██║██████╔╝"
    echo "  ╚██╗ ██╔╝██║██║╚██╗██║██║██╔══██╗"
    echo "   ╚████╔╝ ██║██║ ╚████║██║██║  ██║"
    echo "    ╚═══╝  ╚═╝╚═╝  ╚═══╝╚═╝╚═╝  ╚═╝"
    echo -e "${NC}${DIM}  iNiR for Void Linux${NC}"
    echo ""
}

tui_title()   { echo -e "\n${BOLD}${BLUE}$1${NC}"; }
tui_step()    { echo -e "\n${CYAN}==>${NC} ${BOLD}$1${NC}"; }
tui_success() { echo -e "  ${GREEN}✓${NC} $1"; }
tui_warn()    { echo -e "  ${YELLOW}!${NC} $1"; }
tui_error()   { echo -e "  ${RED}✗${NC} $1"; }
tui_info()    { echo -e "  ${BLUE}·${NC} $1"; }
tui_dim()     { echo -e "  ${DIM}$1${NC}"; }

tui_divider() { echo -e "${DIM}────────────────────────────────────────${NC}"; }

tui_confirm() {
    local msg="$1"
    local default="${2:-yes}"
    local prompt
    [[ "$default" == "yes" ]] && prompt="[Y/n]" || prompt="[y/N]"
    echo -ne "  ${YELLOW}?${NC} $msg $prompt "
    read -r answer
    answer="${answer:-$default}"
    [[ "$answer" =~ ^[Yy] ]]
}

tui_choose() {
    local prompt="$1"; shift
    local options=("$@")
    echo -e "\n  ${BOLD}$prompt${NC}"
    for i in "${!options[@]}"; do
        echo -e "  ${CYAN}$((i+1))${NC}) ${options[$i]}"
    done
    echo -ne "\n  ${YELLOW}→${NC} "
    read -r choice
    echo "${options[$((choice-1))]}"
}

###############################################################################
# Checks
###############################################################################
prevent_sudo_or_root() {
    if [[ "$EUID" -eq 0 ]]; then
        tui_error "Don't run as root or with sudo!"
        exit 1
    fi
}

check_void() {
    if ! command -v xbps-install &>/dev/null; then
        tui_error "This installer is for Void Linux only!"
        exit 1
    fi
}

###############################################################################
# Package installation
###############################################################################
pkg_install() {
    sudo xbps-install -Sy "$@"
}

###############################################################################
# Help
###############################################################################
show_help() {
    echo ""
    tui_title "ViNiR setup"
    echo ""
    echo -e "  ${BOLD}Usage:${NC} ./setup [command] [options]"
    echo ""
    echo -e "  ${BOLD}Commands:${NC}"
    tui_dim "  (none)      Interactive menu"
    tui_dim "  install     Full installation"
    tui_dim "  update      Pull latest changes and sync"
    tui_dim "  doctor      Diagnose and fix problems"
    tui_dim "  uninstall   Remove ViNiR"
    echo ""
    echo -e "  ${BOLD}Options:${NC}"
    tui_dim "  -y, --yes   Skip prompts"
    tui_dim "  -h, --help  Show this help"
    echo ""
}

###############################################################################
# TUI Menu
###############################################################################
tui_menu() {
    clear
    tui_banner

    local is_installed=false
    [[ -d "${HOME}/.config/quickshell/ii" ]] && is_installed=true

    if $is_installed; then
        tui_info "ViNiR is installed"
        echo ""
        tui_divider
    fi

    echo ""
    local choice
    if $is_installed; then
        choice=$(tui_choose "What would you like to do?" \
            "Update" "Doctor" "Reinstall" "Uninstall" "Help" "Exit")
    else
        choice=$(tui_choose "What would you like to do?" \
            "Install" "Help" "Exit")
    fi

    case "$choice" in
        Install|Reinstall) run_install ;;
        Update) run_update ;;
        Doctor) run_doctor ;;
        Uninstall) run_uninstall ;;
        Help) show_help; read -rp "  Press Enter to continue..." ;;
        *) exit 0 ;;
    esac
}

###############################################################################
# Install
###############################################################################
run_install() {
    clear
    tui_banner
    tui_title "Installing ViNiR"
    echo ""

    check_void
    prevent_sudo_or_root

    tui_info "Void Linux detected"
    echo ""

    if ! tui_confirm "This will install ViNiR and its dependencies. Continue?"; then
        echo "Cancelled."
        exit 0
    fi

    # ── Step 1: Repositories ─────────────────────────────────────────────────
    tui_step "1/6  Setting up repositories"

    tui_info "Adding Helium Browser repository..."
    echo "repository=https://github.com/OverLessArtem/helium-browser-void/releases/latest/download" \
        | sudo tee /etc/xbps.d/20-helium.conf >/dev/null

    tui_info "Enabling nonfree and multilib..."
    pkg_install void-repo-nonfree void-repo-multilib 2>/dev/null || true
    sudo xbps-install -S >/dev/null 2>&1

    tui_success "Repositories configured"

    # ── Step 2: Dependencies ──────────────────────────────────────────────────
    tui_step "2/6  Installing dependencies"

    local packages=(
        # Core
        git micro wget curl
        # Compositor
        niri wl-clipboard cliphist
        # Audio
        pipewire wireplumber alsa-utils
        # Display
        xorg-minimal xorg-fonts mesa-dri
        # System services
        elogind dbus NetworkManager sddm
        # Wayland tools
        grim slurp
        # Hardware
        brightnessctl playerctl socat fprintd
        # Shell
        fish starship
        # Terminals
        alacritty kitty
        # Apps
        dolphin helium-browser-bin ImageMagick
        fuzzel matugen uv swayidle
        # Fonts
        noto-fonts-emoji font-inter-ttf font-jetbrains-mono-ttf
        font-awesome6-ttf fonts-roboto-ttf
        # Theming
        adwaita-icon-theme adwaita-gtk-theme nwg-look
        meson ninja sassc
        kvantum kvantum-qt6 qt6ct qt5ct
        # KDE/Qt
        plasma-integration kf6-kirigami kf6-syntax-highlighting
        kdialog libxcb-cursor jq kconfig
        # Desktop portal
        xdg-desktop-portal-gtk xdg-desktop-portal-gnome
        shared-mime-info xdg-utils
        # Media/Utils
        ueberzugpp fastfetch v4l-utils libv4l linux-firmware
        efibootmgr
        rust cargo
    )

    tui_info "Installing ${#packages[@]} packages (this may take a while)..."
    pkg_install "${packages[@]}" 2>/dev/null || {
        tui_warn "Some packages may have failed, continuing..."
    }

    tui_success "Dependencies installed"

    # ── Step 3: Quickshell ────────────────────────────────────────────────────
    tui_step "3/6  Setting up Quickshell"

    pkg_install quickshell 2>/dev/null || tui_warn "quickshell not in repos - install manually"

    if ! command -v qs &>/dev/null && command -v quickshell &>/dev/null; then
        sudo ln -sf /usr/bin/quickshell /usr/bin/qs
        tui_success "Symlink qs → quickshell created"
    fi

    tui_success "Quickshell ready"

    # ── Step 4: System setup ─────────────────────────────────────────────────
    tui_step "4/6  System configuration"

    tui_info "Enabling runit services..."
    for svc in dbus elogind NetworkManager sddm; do
        if [[ -d "/etc/sv/$svc" ]] && [[ ! -L "/var/service/$svc" ]]; then
            sudo ln -s /etc/sv/$svc /var/service/ 2>/dev/null && tui_success "$svc enabled"
        fi
    done

    tui_info "Adding user to groups..."
    sudo gpasswd -a "$USER" input >/dev/null 2>&1
    sudo gpasswd -a "$USER" video >/dev/null 2>&1
    tui_success "Groups configured"

    tui_info "Disabling unused ttys..."
    for tty in tty4 tty5 tty6; do
        [[ -L "/var/service/agetty-$tty" ]] && sudo rm /var/service/agetty-$tty
    done

    tui_info "Configuring SDDM..."
    sudo mkdir -p /etc/sddm.conf.d
    cat << 'SDDM_EOF' | sudo tee /etc/sddm.conf.d/niri.conf >/dev/null
[General]
DisplayServer=wayland

[Theme]
Current=pixel
SDDM_EOF
    tui_success "SDDM configured"

    tui_success "System configured"

    # ── Step 5: Config files ──────────────────────────────────────────────────
    tui_step "5/6  Installing config files"

    tui_info "Syncing ViNiR config files..."
    mkdir -p ~/.config/quickshell

    local ii_target="${HOME}/.config/quickshell/ii"

    if [[ "$(realpath "$REPO_ROOT" 2>/dev/null)" == "$(realpath "$ii_target" 2>/dev/null)" ]]; then
        tui_info "Running from install location, skipping copy"
    else
        if [[ -d "$ii_target" ]]; then
            tui_warn "Existing ViNiR found, replacing..."
            rm -rf "$ii_target"
        fi
        cp -r "$REPO_ROOT" "$ii_target"
        tui_success "ViNiR files copied to ~/.config/quickshell/ii"
    fi

    tui_info "Installing fonts..."
    mkdir -p ~/.local/share/fonts
    local font_src="$HOME/.config/quickshell/ii/dots/sddm/pixel/fonts/MaterialSymbolsRounded.ttf"
    [[ -f "$font_src" ]] && cp "$font_src" ~/.local/share/fonts/
    fc-cache -fv >/dev/null 2>&1
    tui_success "Fonts installed"

    tui_info "Setting up Niri config..."
    mkdir -p ~/.config/niri
    if [[ ! -f ~/.config/niri/config.kdl ]] || tui_confirm "Overwrite existing Niri config?"; then
        _write_niri_config
        tui_success "Niri config written"
    else
        tui_info "Niri config skipped"
    fi

    tui_info "Setting up Fish shell..."
    mkdir -p ~/.config/fish
    if [[ ! -f ~/.config/fish/config.fish ]] || tui_confirm "Overwrite existing Fish config?"; then
        _write_fish_config
        tui_success "Fish config written"
    fi

    tui_info "Building adw-gtk3 theme from source..."
    _build_adw_gtk3

    tui_info "Building awww wallpaper daemon from source..."
    _build_awww

    tui_info "Creating directories..."
    mkdir -p ~/Pictures/Screenshots
    mkdir -p ~/.local/share/applications
    mkdir -p ~/.local/bin

    # ── Step 6: Python venv ───────────────────────────────────────────────────
    tui_step "6/6  Setting up Python environment"

    local venv_dir="${HOME}/.local/state/quickshell/.venv"
    local req_file="${HOME}/.config/quickshell/ii/sdata/uv/requirements.txt"

    if command -v uv &>/dev/null && [[ -f "$req_file" ]]; then
        tui_info "Creating Python venv..."
        uv venv --prompt vinir-venv "$venv_dir" 2>/dev/null || true
        if [[ -d "$venv_dir/bin" ]]; then
            source "$venv_dir/bin/activate"
            uv pip install -q -r "$req_file" 2>/dev/null || true
            deactivate
            tui_success "Python packages installed"
        fi
    else
        tui_info "Skipping Python venv (uv not available or no requirements.txt)"
    fi

    # ── Done ──────────────────────────────────────────────────────────────────
    echo ""
    tui_divider
    echo ""
    echo -e "  ${GREEN}${BOLD}ViNiR installed successfully!${NC}"
    echo ""
    tui_info "Next steps:"
    tui_dim "  1. Reboot: sudo reboot"
    tui_dim "  2. Log in via SDDM → Niri session"
    tui_dim "  3. Set wallpaper: Mod+Space → background"
    echo ""
    tui_warn "EFI stub: configure manually with efibootmgr after reboot"
    echo ""
}

###############################################################################
# Update
###############################################################################
run_update() {
    tui_title "Checking for updates..."
    echo ""

    local ii_dir="${HOME}/.config/quickshell/ii"

    if [[ ! -d "$ii_dir/.git" ]]; then
        tui_error "ViNiR is not installed. Run ./setup install first."
        exit 1
    fi

    tui_info "Fetching remote..."
    git -C "$ii_dir" fetch origin main 2>/dev/null

    local local_commit remote_commit
    local_commit=$(git -C "$ii_dir" rev-parse HEAD 2>/dev/null)
    remote_commit=$(git -C "$ii_dir" rev-parse origin/main 2>/dev/null)

    if [[ "$local_commit" == "$remote_commit" ]]; then
        tui_success "Already up to date"
        return 0
    fi

    tui_info "Updates available"
    git -C "$ii_dir" log --oneline "$local_commit".."$remote_commit" 2>/dev/null | while read -r line; do
        tui_dim "  $line"
    done
    echo ""

    if $ask && ! tui_confirm "Pull and apply updates?"; then
        echo "Cancelled."
        return 0
    fi

    tui_info "Pulling changes..."
    git -C "$ii_dir" pull --ff-only origin main 2>/dev/null || {
        tui_error "Git pull failed. You may have local changes."
        tui_info "Try: git -C ~/.config/quickshell/ii stash && ./setup update"
        exit 1
    }
    tui_success "Changes pulled"

    tui_info "Restarting shell..."
    qs kill -c ii 2>/dev/null || true
    sleep 1
    nohup qs -c ii >/dev/null 2>&1 &
    disown
    tui_success "Shell restarted"

    echo ""
    tui_success "ViNiR updated!"
    echo ""
}

###############################################################################
# Doctor
###############################################################################
run_doctor() {
    tui_title "ViNiR Doctor"
    echo ""

    local issues=0

    # Check qs
    if command -v qs &>/dev/null || command -v quickshell &>/dev/null; then
        tui_success "quickshell found"
        if ! command -v qs &>/dev/null; then
            tui_warn "qs symlink missing"
            if tui_confirm "Create symlink?"; then
                sudo ln -sf /usr/bin/quickshell /usr/bin/qs
                tui_success "Symlink created"
            fi
        fi
    else
        tui_error "quickshell not found"
        ((issues++))
    fi

    # Check niri
    command -v niri &>/dev/null && tui_success "niri found" || { tui_error "niri not found"; ((issues++)); }

    # Check ViNiR
    if [[ -d ~/.config/quickshell/ii ]]; then
        tui_success "ViNiR config found"
    else
        tui_error "ViNiR not installed"
        ((issues++))
    fi

    # Check services
    for svc in dbus elogind NetworkManager; do
        if [[ -L "/var/service/$svc" ]]; then
            tui_success "Service $svc enabled"
        else
            tui_warn "Service $svc not enabled"
            if tui_confirm "Enable $svc?"; then
                sudo ln -s /etc/sv/$svc /var/service/ 2>/dev/null
                tui_success "$svc enabled"
            fi
        fi
    done

    # Check groups
    groups | grep -q input && tui_success "User in 'input' group" || tui_warn "User not in 'input' group"
    groups | grep -q video && tui_success "User in 'video' group" || tui_warn "User not in 'video' group"

    # Check required commands
    local cmds=(grim slurp wl-copy brightnessctl playerctl matugen fish)
    for cmd in "${cmds[@]}"; do
        command -v "$cmd" &>/dev/null && tui_success "$cmd found" || { tui_warn "$cmd not found"; ((issues++)); }
    done

    echo ""
    if [[ $issues -eq 0 ]]; then
        tui_success "No issues found!"
    else
        tui_warn "$issues issue(s) found"
    fi
    echo ""
}

###############################################################################
# Uninstall
###############################################################################
run_uninstall() {
    tui_title "Uninstall ViNiR"
    echo ""
    tui_warn "This will remove ~/.config/quickshell/ii"
    echo ""

    if ! tui_confirm "Are you sure?" "no"; then
        echo "Cancelled."
        return 0
    fi

    qs kill -c ii 2>/dev/null || true
    rm -rf ~/.config/quickshell/ii
    tui_success "ViNiR removed"
    tui_info "Other configs (niri, fish, gtk) were not touched"
    echo ""
}

###############################################################################
# Build adw-gtk3 from source
###############################################################################
# Build awww from source
###############################################################################
_build_awww() {
    local tmp_dir="/tmp/awww-build"
    rm -rf "$tmp_dir"

    if ! command -v cargo &>/dev/null; then
        tui_warn "cargo not found, skipping awww build"
        return 1
    fi

    tui_info "Cloning awww..."
    git clone --depth=1 https://codeberg.org/LGFae/awww.git "$tmp_dir" 2>/dev/null || {
        tui_warn "Failed to clone awww, skipping"
        return 1
    }

    cd "$tmp_dir"
    tui_info "Building awww with cargo (this may take a while)..."
    cargo build --release 2>/dev/null || { tui_warn "cargo build failed"; cd ~; return 1; }

    mkdir -p ~/.local/bin
    cp target/release/awww ~/.local/bin/
    cp target/release/awww-daemon ~/.local/bin/ 2>/dev/null || true

    if [[ -d completions ]]; then
        mkdir -p ~/.config/fish/completions
        cp completions/awww.fish ~/.config/fish/completions/ 2>/dev/null || true
    fi

    cd ~
    rm -rf "$tmp_dir"
    tui_success "awww installed to ~/.local/bin/awww"
}

###############################################################################
_build_adw_gtk3() {
    local tmp_dir="/tmp/adw-gtk3-build"
    rm -rf "$tmp_dir"
    
    tui_info "Cloning adwaita-gtk3-gtk4-theme..."
    git clone --depth=1 https://github.com/ronny-rentner/adwaita-gtk3-gtk4-theme.git "$tmp_dir" 2>/dev/null || {
        tui_warn "Failed to clone adw-gtk3, skipping theme build"
        return 1
    }
    
    cd "$tmp_dir"
    tui_info "Building with meson..."
    meson setup build --prefix=/usr 2>/dev/null || { tui_warn "meson setup failed"; cd ~; return 1; }
    ninja -C build 2>/dev/null || { tui_warn "ninja build failed"; cd ~; return 1; }
    sudo ninja -C build install 2>/dev/null || { tui_warn "ninja install failed"; cd ~; return 1; }
    
    cd ~
    rm -rf "$tmp_dir"
    
    gsettings set org.gnome.desktop.interface gtk-theme 'adw-gtk3-dark' 2>/dev/null || true
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
    
    tui_success "adw-gtk3-dark installed and applied"
}

###############################################################################
# Config writers
###############################################################################
_write_niri_config() {
    cat > ~/.config/niri/config.kdl << 'NIRI_EOF'
prefer-no-csd

hotkey-overlay {
    skip-at-startup
}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

output "eDP-1" {
    mode "1920x1200@60"
    scale 1
    transform "normal"
    position x=0 y=0
}

input {
    keyboard {
        xkb {
            layout "us,ru"
            options "grp:alt_shift_toggle"
        }
        repeat-delay 250
        repeat-rate 50
    }
    touchpad {
        tap
        tap-button-map "left-right-middle"
        natural-scroll
    }
    mouse {
        accel-profile "flat"
    }
    mod-key "Super"
    mod-key-nested "Alt"
    focus-follows-mouse max-scroll-amount="0%"
}

layout {
    gaps 25
    background-color "transparent"
    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5 }

    border { off }
    focus-ring { off }

    shadow {
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }

    struts { }
}

gestures {
    hot-corners { }
}

cursor {
    xcursor-size 24
    hide-when-typing
}

overview {
    zoom 0.75
}

window-rule {
    geometry-corner-radius 16
    clip-to-geometry true
}

window-rule {
    match is-active=false
    opacity 0.9
}

animations {
    workspace-switch {
        spring damping-ratio=0.78 stiffness=600 epsilon=0.0001
    }
    window-open {
        spring damping-ratio=0.82 stiffness=500 epsilon=0.0001
    }
    window-close {
        spring damping-ratio=0.88 stiffness=900 epsilon=0.0001
    }
    horizontal-view-movement {
        spring damping-ratio=0.80 stiffness=550 epsilon=0.0001
    }
    window-movement {
        spring damping-ratio=0.85 stiffness=650 epsilon=0.0001
    }
    window-resize {
        spring damping-ratio=0.88 stiffness=700 epsilon=0.0001
    }
    config-notification-open-close {
        spring damping-ratio=0.90 stiffness=800 epsilon=0.0001
    }
    screenshot-ui-open {
        spring damping-ratio=0.85 stiffness=750 epsilon=0.0001
    }
}

environment {
    XDG_CURRENT_DESKTOP "niri"
    QT_QPA_PLATFORM "wayland"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    QT_LOGGING_RULES "quickshell.dbus.properties=false"
    QT_QPA_PLATFORMTHEME "kde"
    GBM_BACKEND "amdgpu"
    __GLX_VENDOR_LIBRARY_NAME "mesa"
    LIBVA_DRIVER_NAME "radeonsi"
    VDPAU_DRIVER "radeonsi"
    __GL_THREADED_OPTIMIZATIONS "1"
    mesa_glthread "true"
    GDK_BACKEND "wayland,x11"
    SDL_VIDEODRIVER "wayland"
    XDG_SESSION_TYPE "wayland"
}

spawn-at-startup "bash" "-c" "wl-paste --watch cliphist store &"
spawn-at-startup "/usr/lib/polkit-kde-authentication-agent-1"
spawn-at-startup "qs" "-c" "ii"

binds {
    Mod+Tab repeat=false { toggle-overview; }
    Mod+Shift+E { quit; }
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    Alt+Tab { spawn "qs" "-c" "ii" "ipc" "call" "altSwitcher" "next"; }
    Alt+Shift+Tab { spawn "qs" "-c" "ii" "ipc" "call" "altSwitcher" "previous"; }

    Super+G { spawn "qs" "-c" "ii" "ipc" "call" "overlay" "toggle"; }
    Mod+Space repeat=false { spawn "qs" "-c" "ii" "ipc" "call" "overview" "toggle"; }
    Mod+V { spawn "qs" "-c" "ii" "ipc" "call" "clipboard" "toggle"; }
    Mod+Alt+L allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "lock" "activate"; }
    Mod+Shift+S { spawn "qs" "-c" "ii" "ipc" "call" "region" "screenshot"; }
    Mod+Shift+X { spawn "qs" "-c" "ii" "ipc" "call" "region" "ocr"; }
    Mod+Shift+A { spawn "qs" "-c" "ii" "ipc" "call" "region" "search"; }
    Ctrl+Alt+T { spawn "qs" "-c" "ii" "ipc" "call" "wallpaperSelector" "toggle"; }
    Mod+Comma { spawn "qs" "-c" "ii" "ipc" "call" "settings" "open"; }
    Mod+Slash { spawn "qs" "-c" "ii" "ipc" "call" "cheatsheet" "toggle"; }
    Mod+Shift+W { spawn "qs" "-c" "ii" "ipc" "call" "panelFamily" "cycle"; }

    Mod+T { spawn "alacritty"; }
    Mod+Return { spawn "alacritty"; }
    Super+E { spawn "dolphin"; }
    Super+W { spawn "helium-browser"; }

    Mod+Q repeat=false { close-window; }
    Mod+D { maximize-column; }
    Mod+F { fullscreen-window; }
    Mod+A { toggle-window-floating; }

    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }
    Mod+H { focus-column-left; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }
    Mod+L { focus-column-right; }

    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Right { move-column-right; }
    Mod+Shift+Up    { move-window-up; }
    Mod+Shift+Down  { move-window-down; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }

    Print { spawn "bash" "-c" "mkdir -p ~/Pictures/Screenshots && FILE=~/Pictures/Screenshots/$(date '+%Y-%m-%d %H-%M-%S').png && grim $FILE && wl-copy < $FILE"; }
    Ctrl+Print { spawn "bash" "-c" "mkdir -p ~/Pictures/Screenshots && FILE=~/Pictures/Screenshots/$(date '+%Y-%m-%d %H-%M-%S').png && grim $FILE && wl-copy < $FILE"; }
    Alt+Print { spawn "bash" "-c" "mkdir -p ~/Pictures/Screenshots && FILE=~/Pictures/Screenshots/$(date '+%Y-%m-%d %H-%M-%S').png && grim -g \"$(slurp)\" $FILE && wl-copy < $FILE"; }

    XF86AudioRaiseVolume  allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "audio" "volumeUp"; }
    XF86AudioLowerVolume  allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "audio" "volumeDown"; }
    XF86AudioMute         allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "audio" "mute"; }
    XF86AudioMicMute      allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "audio" "micMute"; }
    XF86MonBrightnessUp   allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "brightness" "increment"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "qs" "-c" "ii" "ipc" "call" "brightness" "decrement"; }
    XF86AudioPlay  { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "playPause"; }
    XF86AudioPause { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "playPause"; }
    XF86AudioNext  { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "next"; }
    XF86AudioPrev  { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "previous"; }

    Ctrl+Mod+Space { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "playPause"; }
    Mod+Alt+N { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "next"; }
    Mod+Alt+P { spawn "qs" "-c" "ii" "ipc" "call" "mpris" "previous"; }
    Mod+Shift+M { spawn "qs" "-c" "ii" "ipc" "call" "audio" "mute"; }
    Mod+Shift+Q { spawn "qs" "-c" "ii" "ipc" "call" "session" "toggle"; }
}

layer-rule {
    match namespace="quickshell:iiBackdrop"
    place-within-backdrop true
    opacity 1.0
}

layer-rule {
    match namespace="quickshell:wBackdrop"
    place-within-backdrop true
    opacity 1.0
}
NIRI_EOF
}

_write_fish_config() {
    cat > ~/.config/fish/config.fish << 'FISH_EOF'
if status is-interactive
    starship init fish | source
end

fish_add_path ~/.local/bin
fish_add_path ~/.cargo/bin

set -gx GTK_THEME adw-gtk3-dark
FISH_EOF
}

###############################################################################
# Parse args
###############################################################################
ask=true
COMMAND=""

while [[ $# -gt 0 ]]; do
    case $1 in
        install)   COMMAND="install"; shift ;;
        update)    COMMAND="update"; shift ;;
        doctor)    COMMAND="doctor"; shift ;;
        uninstall) COMMAND="uninstall"; shift ;;
        -y|--yes)  ask=false; shift ;;
        -h|--help) show_help; exit 0 ;;
        *) echo "Unknown: $1"; show_help; exit 1 ;;
    esac
done

###############################################################################
# Run
###############################################################################
case "$COMMAND" in
    install)   run_install ;;
    update)    run_update ;;
    doctor)    run_doctor ;;
    uninstall) run_uninstall ;;
    "")        tui_menu ;;
esac
